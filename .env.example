# Optional values for local tooling/deploy templates.
# This static site does not read .env directly in the browser.
NSSGOLF_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NSSGOLF_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
NSSGOLF_AUTH_CALLBACK_URL=http://localhost:8080/auth/callback
# External Cloudflare Worker secret name for Team Up H2H proxying.
# This static site does not read the value directly; the Worker stores it as a secret.
NSSGOLF_TEAMUP_API_KEY=teamup_api_key_REPLACE_ME

# Discord member scan bot.
# Store real values in a local .env file or your deployment provider's secrets.
DISCORD_BOT_TOKEN=discord_bot_token_REPLACE_ME
DISCORD_GUILD_ID=discord_server_id_REPLACE_ME

# Server-side Supabase key for the Discord bot only.
# Do not expose this value in browser JavaScript or public GitHub files.
NSSGOLF_SUPABASE_SERVICE_ROLE_KEY=service_role_key_REPLACE_ME
