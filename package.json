{
  "name": "nssgolf",
  "version": "1.0.0",
  "description": "- Primary sign-in method: Discord OAuth via Supabase Auth (`signInWithOAuth` with provider `discord`) - Canonical callback route: `/auth/callback` - Current visible login UI: `/lightningcup/index.html` - For local callback testing, run the site on localhost and add a redirect URL like `http://localhost:8080/auth/callback` in Supabase Auth settings. - Optional runtime override for static deployments:",
  "main": "index.js",
  "scripts": {
    "build:home-tabs": "esbuild home-tabs.jsx --bundle --format=esm --target=es2020 --minify --outfile=home-tabs.bundle.js",
    "build:lightningcup-radix": "esbuild lightningcup/radix-controls.jsx --bundle --format=esm --target=es2020 --minify --outfile=lightningcup/radix-controls.bundle.js",
    "build:noptational-tabs": "esbuild noptational-tabs.jsx --bundle --format=esm --target=es2020 --minify --outfile=noptational-tabs.bundle.js",
    "build:superleague-tabs": "esbuild superleague-tabs.jsx --bundle --format=esm --target=es2020 --minify --outfile=superleague-tabs.bundle.js",
    "build:worldcup-tabs": "esbuild worldcup-tabs.jsx --bundle --format=esm --target=es2020 --minify --outfile=worldcup-tabs.bundle.js",
    "check:player-shell": "node scripts/sync-player-shell.js",
    "discord:scan-members": "node bot/scan-members.js",
    "discord:global-ranks": "node bot/global-ranks-bot.js",
    "internal-ranked:fetch": "node bot/internal-ranked.js fetch",
    "internal-ranked:replay": "node bot/internal-ranked.js replay",
    "internal-ranked:replay-nps": "node bot/internal-ranked.js replay-nps",
    "internal-ranked:replay-oawp": "node bot/internal-ranked.js replay-oawp",
    "internal-ranked:replay-pl": "node bot/internal-ranked.js replay-pl",
    "internal-ranked:sync": "node bot/internal-ranked.js sync",
    "internal-ranked:sync-nps": "node bot/internal-ranked.js sync-nps",
    "internal-ranked:sync-oawp": "node bot/internal-ranked.js sync-oawp",
    "internal-ranked:sync-pl": "node bot/internal-ranked.js sync-pl",
    "proleague:aliases:suggest": "node bot/proleague-player-aliases.js suggest",
    "proleague:aliases:export-sql": "node bot/proleague-player-aliases.js export-sql",
    "proleague:aliases:import": "node bot/proleague-player-aliases.js import",
    "sync:player-shell": "node scripts/sync-player-shell.js --write",
    "test:global-ranks": "node bot/global-ranks-core.test.js",
    "test:internal-ranked": "node bot/internal-ranked-core.test.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextweeknews/nssgolf.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nextweeknews/nssgolf/issues"
  },
  "homepage": "https://github.com/nextweeknews/nssgolf#readme",
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.107.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "flag-icons": "^7.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
